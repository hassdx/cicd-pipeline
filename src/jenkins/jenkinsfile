pipline {
    agent any

    enviroment {
        DOCKERHUB_CREDENTIALS=credentials('dockerhub')
    }

    tools {
        dockerTool 'docker'
        nodejs 'node-20'

    }

    stages {
        stage('build') {
            steps {
                sh '''
                echo 'install the dependincies ........'
                npm install
                '''
            }
        }

        stage('test') {
            steps {
                sh '''
                echo 'test the installed dependencies ..........'
                test npm
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin

                docker build -t hassdx/cicd-web-container:main .
                docker push hassdx/cicd-web-container:main

                '''

            }
        }
    } 
}